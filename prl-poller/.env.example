# PRL Poller environment configuration
#
# Copy this file to .env and fill in real values.
# Never commit .env to git.

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# PracticeOS Supabase project URL and service-role key.
# Service role is needed to read cm_sftp_endpoints, write cm_prl_sftp_runs,
# and read/update cm_prl_exports without RLS friction.
SUPABASE_URL=https://wlkwmfxmrnjqvcsbwksk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Webhook authentication
# -----------------------------------------------------------------------------
# Shared secret the poller uses when calling prl-ingest-from-sftp on Supabase.
# This same value MUST be set as POLLER_SHARED_SECRET in Supabase project secrets.
# Generate a long random string (32+ chars). Example: openssl rand -hex 32
POLLER_SHARED_SECRET=

# -----------------------------------------------------------------------------
# Admin server authentication
# -----------------------------------------------------------------------------
# Shared secret you use when curl-ing the poller's tiny Express admin server
# to manually trigger a pull/push. Different from POLLER_SHARED_SECRET.
# Generate a long random string. Example: openssl rand -hex 32
POLLER_ADMIN_SECRET=

# -----------------------------------------------------------------------------
# Schedule (cron expressions, droplet local time)
# -----------------------------------------------------------------------------
# Daily ticks. Each tick walks active endpoints and decides per-endpoint
# whether today is a scheduled run for that endpoint.
# Default: pull tick at 6am, push tick at 6:15am (droplet local TZ).
# Use America/New_York TZ on the droplet OR adjust these to UTC if droplet is UTC.
PULL_TICK_CRON=0 6 * * *
PUSH_TICK_CRON=15 6 * * *

# Override the timezone used by node-cron. If unset, uses droplet local TZ.
# Recommend explicit America/New_York to match NC Medicaid spec timing.
CRON_TIMEZONE=America/New_York

# -----------------------------------------------------------------------------
# Admin server
# -----------------------------------------------------------------------------
# Port for the tiny Express admin server. Bind to localhost only behind nginx
# in production, or expose via a reverse proxy with proper auth.
ADMIN_PORT=3001
ADMIN_BIND=127.0.0.1

# -----------------------------------------------------------------------------
# Operational
# -----------------------------------------------------------------------------
# How many minutes between considering an endpoint "stale" and alerting.
# (Used in /status endpoint, not cron-driven yet.)
STALE_THRESHOLD_MINUTES=120

# Set to 'verbose' for noisy logs during onboarding, 'normal' for production.
LOG_LEVEL=normal
